{
  "post_invocation_hooks": [
    {
      "name": "agy-hud-configure-statusline",
      "command": "node -e \"const fs=require('fs'),os=require('os'),path=require('path'),cp=require('child_process');const home=os.homedir();const runtime=process.env.AGY_HUD_RUNTIME_DIR||path.join(home,'.gemini','antigravity-cli','agy-hud-runtime');const repo=process.env.AGY_HUD_REPO_URL||'https://github.com/icebear0828/agy-hud.git';const settingsPath=(()=>{const c=[path.join(home,'.gemini','antigravity-cli','settings.json'),process.env.XDG_DATA_HOME&&path.join(process.env.XDG_DATA_HOME,'antigravity-cli','settings.json'),process.env.APPDATA&&path.join(process.env.APPDATA,'antigravity-cli','settings.json'),process.env.LOCALAPPDATA&&path.join(process.env.LOCALAPPDATA,'antigravity-cli','settings.json')].filter(Boolean);return c.find(p=>fs.existsSync(p))||c[0]})();const hud=path.join(runtime,'extensions','bin','agy-hud.js');const run=a=>cp.execFileSync('git',a,{stdio:'ignore'});const clone=()=>{const tmp=runtime+'-'+process.pid+'-'+Date.now();fs.rmSync(tmp,{recursive:true,force:true});fs.mkdirSync(path.dirname(runtime),{recursive:true});run(['clone','--depth=1',repo,tmp]);fs.rmSync(runtime,{recursive:true,force:true});fs.renameSync(tmp,runtime);};try{if(fs.existsSync(path.join(runtime,'.git'))){try{run(['-C',runtime,'fetch','--depth=1','origin','HEAD']);run(['-C',runtime,'reset','--hard','FETCH_HEAD']);}catch{clone();}}else{try{clone();}catch{}}}catch{}if(!fs.existsSync(hud))process.exit(0);let s={};try{if(fs.existsSync(settingsPath))s=JSON.parse(fs.readFileSync(settingsPath,'utf8'));}catch{}const cmd=process.platform==='win32'?'node \\\"'+hud+'\\\"':'\\\"'+process.execPath+'\\\" \\\"'+hud+'\\\"';if(!s.statusLine||s.statusLine.command!==cmd){s.statusLine={type:'command',command:cmd};fs.mkdirSync(path.dirname(settingsPath),{recursive:true});fs.writeFileSync(settingsPath,JSON.stringify(s,null,2));}\"",
      "timeout_ms": 60000
    }
  ]
}
