{
  "name": "agy-hud",
  "version": "0.1.12",
  "description": "Premium HUD for Antigravity CLI",
  "main": "extensions/index.js",
  "pi": {
    "skills": ["skills/*/SKILL.md"]
  },
  "files": [
    "extensions",
    "scripts",
    "skills",
    "plugin.json",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icebear0828/agy-hud.git"
  },
  "homepage": "https://github.com/icebear0828/agy-hud#readme",
  "bugs": {
    "url": "https://github.com/icebear0828/agy-hud/issues"
  },
  "scripts": {
    "test": "node --test tests/unit/*.test.mjs",
    "e2e": "node scripts/run-e2e.js",
    "diagnose:auth": "node scripts/diagnose-auth.js",
    "diagnose:auth:remote": "node scripts/diagnose-auth-remote.js",
    "setup:runtime": "node scripts/setup-runtime.js",
    "verify:install-display": "node scripts/verify-install-display.js",
    "verify:install-display:remote": "node scripts/verify-install-display-remote.js",
    "verify:setup-display:remote": "node scripts/verify-setup-display-remote.js",
    "serve:release": "node scripts/serve-release.js",
    "serve:source": "node scripts/serve-source.js"
  },
  "keywords": [
    "antigravity",
    "cli",
    "hud",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
