{
  "name": "agy-hud",
  "version": "0.1.10",
  "description": "Premium HUD for Antigravity CLI",
  "main": "extensions/index.js",
  "pi": {
    "extensions": ["extensions/index.js"],
    "skills": ["skills/*.md"]
  },
  "files": [
    "extensions",
    "parser.js",
    "renderer.js",
    "config.js",
    "git.js",
    "skills",
